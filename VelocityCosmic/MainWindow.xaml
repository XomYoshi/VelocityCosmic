<Window x:Class="VelocityCosmic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:VelocityCosmic"
        Title="VelocityCosmic" Background="#080808" AllowsTransparency="False"
        WindowStartupLocation="CenterScreen" WindowStyle="None" Height="620" Width="920" Icon="/Resource/tabs/vel/vel_meteor-hq.png">

    <FrameworkElement.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Storyboard x:Key="CloseSettingsStoryboard">
            <DoubleAnimation Storyboard.TargetName="SettingsBackDrop" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="SettingsHostBorder" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="SettingsScale" Storyboard.TargetProperty="ScaleX" To="0.94" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="SettingsScale" Storyboard.TargetProperty="ScaleY" To="0.94" Duration="0:0:0.18"/>
        </Storyboard>
        <Storyboard x:Key="OpenSettingsStoryboard">
            <DoubleAnimation Storyboard.TargetName="SettingsBackDrop" Storyboard.TargetProperty="Opacity" From="0" To="0.6" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="SettingsHostBorder" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="SettingsScale" Storyboard.TargetProperty="ScaleX" From="0.94" To="1" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="SettingsScale" Storyboard.TargetProperty="ScaleY" From="0.94" To="1" Duration="0:0:0.18"/>
        </Storyboard>
        <Storyboard x:Key="OpenWelcomeStoryboard">
            <DoubleAnimation Storyboard.TargetName="WelcomeBackDrop" Storyboard.TargetProperty="Opacity" From="0" To="0.6" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="WelcomeBorderMessageHost" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="WelcomeScale" Storyboard.TargetProperty="ScaleX" From="0.94" To="1" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="WelcomeScale" Storyboard.TargetProperty="ScaleY" From="0.94" To="1" Duration="0:0:0.18"/>
        </Storyboard>
        <Storyboard x:Key="CloseWelcomeStoryboard">
            <DoubleAnimation Storyboard.TargetName="WelcomeBackDrop" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="WelcomeBorderMessageHost" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="WelcomeScale" Storyboard.TargetProperty="ScaleX" To="0.94" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="WelcomeScale" Storyboard.TargetProperty="ScaleY" To="0.94" Duration="0:0:0.18"/>
        </Storyboard>
    </FrameworkElement.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0.5" ResizeBorderThickness="4" GlassFrameThickness="1" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Image x:Name="BackgroundImage" Stretch="UniformToFill" Opacity="0" Visibility="Collapsed" IsHitTestVisible="False" Panel.ZIndex="1" Grid.RowSpan="2"/>

        <Border MouseLeftButtonDown="ChromeDrag" x:Name="Titlebar" Grid.Row="0" Background="Transparent" BorderThickness="0,0,0,1.3" BorderBrush="#191919">
            <Grid>
                <StackPanel x:Name="TitleLeftSide" Orientation="Horizontal" HorizontalAlignment="Left">
                    <Border x:Name="IconHost" Opacity="0.7" Margin="7,3,0,3">
                        <Image x:Name="VelIco" Source="/Resource/tabs/vel/vel_meteor-HQ.png" Height="25" Width="27" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                </StackPanel>
                <TextBlock x:Name="VelVersionLocal" ToolTip="Installed Velocity version" Text="1.1.8" FontWeight="SemiBold" Opacity="0.5" Margin="0,0,0,0" FontFamily="{StaticResource Inter}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontSize="16" Height="18"/>
                <StackPanel x:Name="TitleRightSide" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Click="MinimizeButton_Click" x:Name="MinimizeButton" Focusable="False" Style="{DynamicResource WindowControlButtonStyle}" Width="45" Height="36" Background="Transparent" BorderThickness="0" ToolTip="Minimize">
                        <TextBlock FontFamily="{StaticResource SegoeFluentIcons}" FontSize="10" Opacity="0.7" Foreground="White" Text=""/>
                    </Button>
                    <Button Click="MaximizeButton_Click" x:Name="MaximizeButton" Focusable="False" Style="{DynamicResource WindowControlButtonStyle}" Width="45" Height="36" Background="Transparent" BorderThickness="0" ToolTip="Maximize">
                        <TextBlock FontFamily="{StaticResource SegoeFluentIcons}" FontSize="10" Opacity="0.7" Foreground="White" Text=""/>
                    </Button>
                    <Button Click="CloseButton_Click" x:Name="CloseButton" Focusable="False" Style="{StaticResource CloseButtonStyle}" Width="45" Height="36" Background="Transparent" BorderThickness="0" ToolTip="Close">
                        <TextBlock FontFamily="{StaticResource SegoeFluentIcons}" FontSize="10" Opacity="0.7" Foreground="White" Text=""/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="MainGrid" Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310" MinWidth="200"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="ExplorerBorder" Grid.Column="0" Margin="0" CornerRadius="0" Background="Transparent" BorderThickness="0,0,1.3,0" BorderBrush="#191919">
                <Grid>
                    <ListBox SelectionChanged="ExplorerListBox_SelectionChanged" 
                             PreviewMouseRightButtonDown="ExplorerListBox_PreviewMouseRightButtonDown" 
                             x:Name="ExplorerListBox" 
                             Focusable="False" 
                             Background="Transparent" 
                             BorderThickness="0" 
                             ItemContainerStyle="{StaticResource ExplorerTreeListBoxStyle}" 
                             Margin="0,38,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Foreground="White" FontFamily="{StaticResource Inter}" FontSize="13" VerticalAlignment="Center" Opacity="0.8"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ItemsControl.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="{x:Type GroupItem}">
                                        <Setter Property="FrameworkElement.Margin" Value="0,15,0,5"/>
                                    </Style>
                                </GroupStyle.ContainerStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Grid Margin="18,0,0,5">
                                            <TextBlock Focusable="False" Foreground="#CCCCCC" Opacity="0.5" FontSize="11" FontWeight="Bold" FontFamily="{StaticResource Inter}" Text="{Binding Name}"/>
                                        </Grid>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ItemsControl.GroupStyle>
                    </ListBox>

                    <Border Height="38" VerticalAlignment="Top" BorderBrush="#191919" BorderThickness="0,0,0,1.3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Grid Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="38">
                                <Image Source="/Resource/Exp/Search.png" RenderOptions.BitmapScalingMode="HighQuality" Opacity="0.5" HorizontalAlignment="Left" Width="20" Height="20" Margin="10,0,0,0"/>
                                <TextBox TextChanged="SearchTextBox_TextChanged" x:Name="SearchTextBoxExp" Background="Transparent" FontFamily="{StaticResource Inter}" FontSize="15" CaretBrush="White" Foreground="White" Opacity="0.7" BorderThickness="0" BorderBrush="Transparent" VerticalAlignment="Center" Margin="40,0,0,0" HorizontalAlignment="Stretch">
                                    <FrameworkElement.Style>
                                        <Style TargetType="{x:Type TextBox}">
                                            <Setter Property="Control.Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type TextBox}">
                                                        <Grid>
                                                            <ScrollViewer x:Name="PART_ContentHost"/>
                                                            <TextBlock x:Name="SettingsSearchPlaceholder" FontFamily="{StaticResource Inter}" Text="Search Explorer.." FontStyle="Italic" Foreground="White" Opacity="0.4" IsHitTestVisible="False" Margin="2,0,0,0" VerticalAlignment="Center" Visibility="{Binding Text.IsEmpty, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </FrameworkElement.Style>
                                </TextBox>
                            </Grid>
                            <Button Click="ReloadExplroer_Click" x:Name="ReloadExplroer" Focusable="False" Style="{StaticResource HoverOpacityButton}" Grid.Column="1" VerticalAlignment="Top" Margin="0,5,10,0" Width="28" Height="28" ToolTip="Refresh">
                                <Image x:Name="ReloadImage" Source="/Resource/Exp/FluentRefresh.png" RenderOptions.BitmapScalingMode="HighQuality" Width="20" Height="20" Margin="0" RenderTransformOrigin="0.5,0.5">
                                    <UIElement.RenderTransform>
                                        <RotateTransform Angle="0"/>
                                    </UIElement.RenderTransform>
                                </Image>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" Cursor="SizeWE"/>

            <Border x:Name="PrimaryHost" Grid.Column="2" Margin="0" CornerRadius="0" Background="#080808">
                <Grid x:Name="SecondMainGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="170" MinHeight="170"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="BottomHostElement" Grid.Row="2" BorderBrush="#191919" BorderThickness="0,1.3,0,0">
                        <Grid>
                            <Border Height="40" VerticalAlignment="Top" BorderBrush="#191919" BorderThickness="0,0,0,1.3">
                                <Grid Margin="5,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Click="ExecuteButton_Click" Focusable="False" Grid.Column="0" Style="{StaticResource WebIconButtonStyle}" Margin="10">
                                        <StackPanel Orientation="Horizontal" RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image RenderOptions.BitmapScalingMode="HighQuality" Source="/Resource/Bt/RunFileExe.png" Width="18" Height="18" Margin="0,0,5,0"/>
                                            <TextBlock Text="Execute" FontFamily="{StaticResource Inter}" VerticalAlignment="Center" Foreground="#CCCCCC"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Click="ClearButton_Click" Focusable="False" Grid.Column="1" Style="{StaticResource WebIconButtonStyle}" Margin="10">
                                        <StackPanel Orientation="Horizontal" RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image RenderOptions.BitmapScalingMode="HighQuality" Source="/Resource/Bt/Clear.png" Width="18" Height="18" Margin="0,0,8,0"/>
                                            <TextBlock Text="Clear" VerticalAlignment="Center" FontFamily="{StaticResource Inter}" Foreground="#CCCCCC"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Click="OpenButton_Click" Focusable="False" Grid.Column="2" Style="{StaticResource WebIconButtonStyle}" Margin="10">
                                        <StackPanel Orientation="Horizontal" RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image RenderOptions.BitmapScalingMode="HighQuality" Source="/Resource/Bt/OpenFile.png" Width="18" Height="18" Margin="0,0,8,0"/>
                                            <TextBlock Text="Open" VerticalAlignment="Center" Foreground="#CCCCCC"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Click="SaveButton_Click" Focusable="False" Grid.Column="3" Style="{StaticResource WebIconButtonStyle}" Margin="10">
                                        <StackPanel Orientation="Horizontal" RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image RenderOptions.BitmapScalingMode="HighQuality" Source="/Resource/Bt/SaveFile.png" Width="18" Height="18" Margin="0,0,8,0"/>
                                            <TextBlock Text="Save" VerticalAlignment="Center" Foreground="#CCCCCC"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Click="InjectButton_Click" Focusable="False" Grid.Column="6" Style="{StaticResource WebIconButtonStyle}" Margin="10">
                                        <StackPanel Orientation="Horizontal" RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image Source="/Resource/Bt/Inject1.png" Width="18" Height="18" Margin="0,0,8,0"/>
                                            <TextBlock Text="Inject" VerticalAlignment="Center" Foreground="#CCCCCC"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                            <Border Margin="0,40,0,0">
                                <Grid>
                                    <RichTextBox x:Name="TerminalBox" Focusable="False" IsDocumentEnabled="True" Background="#080808" BorderThickness="0" Foreground="#FFFFFF" FontFamily="{StaticResource JetBrainsMono}" FontSize="14" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" VerticalContentAlignment="Top" Margin="3,33,0,0"/>
                                    <TextBlock Text="Output" Foreground="White" FontWeight="Medium" Opacity="0.7" FontFamily="{StaticResource Inter}" FontSize="17" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,9,0,0"/>
                                    <Button Click="OpenSettings_Click" Focusable="False" Style="{StaticResource HoverOpacityButton}" Background="Black" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,10,0" Width="28" Height="28" ToolTip="Settings">
                                        <Image Source="/Resource/Bt/Cog_Settings-Fluent.png" RenderOptions.BitmapScalingMode="HighQuality" Width="20" Height="20" Margin="0,0,0,0"/>
                                    </Button>
                                    <Button Click="SaveTerminalOutput_Click" Focusable="False" Style="{StaticResource HoverOpacityButton}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,43,0" Width="28" Height="28" ToolTip="Save to File">
                                        <Image Source="/Resource/Bt/SaveFile.png" RenderOptions.BitmapScalingMode="HighQuality" Width="20" Height="20" Margin="0,0,0,0"/>
                                    </Button>
                                    <Button Click="ClearTerminal_Click" Focusable="False" Style="{StaticResource HoverOpacityButton}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,109,0" Width="28" Height="28" ToolTip="Clear Terminal">
                                        <Image Source="/Resource/Bt/Clear.png" RenderOptions.BitmapScalingMode="HighQuality" Width="20" Height="20" Margin="0,0,0,0"/>
                                    </Button>
                                    <Button Click="CopyTerminalOutput_Click" Focusable="False" Style="{StaticResource HoverOpacityButton}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="3,5,76,0" Width="28" Height="28" ToolTip="Copy output">
                                        <Image Source="/Resource/Bt/Copy_Term.png" RenderOptions.BitmapScalingMode="HighQuality" Width="20" Height="20" Margin="0,0,0,0"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Row="1" Height="5" Background="Transparent" HorizontalAlignment="Stretch" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" Cursor="SizeNS"/>

                    <Border x:Name="EditorControl" Grid.Row="0">
                        <Grid>
                            <TabControl x:Name="TabCtrl" 
            Loaded="TabCtrl_Loaded" 
            Background="Transparent" 
            BorderThickness="0" 
            Style="{DynamicResource Tabs}" 
            SelectionChanged="TabCtrl_Loaded"/>

                            <StackPanel x:Name="EmptyStatePanel" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock Text="You currently don't have any script tabs opened!" Foreground="White" FontSize="20" FontFamily="{StaticResource Inter}" FontWeight="SemiBold" Opacity="0.7" TextAlignment="Center" Margin="0,0,0,6"/>
                                <TextBlock Text="Click the '+' in the top right to get started" Foreground="White" FontSize="13" FontFamily="{StaticResource Inter}" Opacity="0.45" TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="SettingsHost" Visibility="Collapsed" Grid.Row="1">
            <Grid>
                <Border x:Name="SettingsBackDrop" Background="Black" Opacity="0.6"/>
                <Border x:Name="SettingsHostBorder" Margin="40" Background="#080808" BorderThickness="2" BorderBrush="#191919" CornerRadius="10" RenderTransformOrigin="0.5,0.5">
                    <UIElement.RenderTransform>
                        <ScaleTransform x:Name="SettingsScale" ScaleX="1" ScaleY="1"/>
                    </UIElement.RenderTransform>
                    <Grid>
                        <Border x:Name="MainSettingsHost">
                            <Grid>
                                <Grid x:Name="SettingsTitlebar" Height="53" VerticalAlignment="Top">
                                    <Button Click="CloseSettings_Click" x:Name="CloseSettingsButton" HorizontalAlignment="Right" Focusable="False" Style="{DynamicResource RoundedCloseButtonStylr}" Width="37" Height="30" Background="Transparent" BorderThickness="0" ToolTip="Close Settings" Margin="0,0,0,23">
                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.7" Foreground="White" Text=""/>
                                    </Button>
                                </Grid>
                                <Border x:Name="SettingsSidebar" CornerRadius="0" Width="280" HorizontalAlignment="Left" Background="Transparent" BorderBrush="#161616" BorderThickness="0,0,1,0">
                                    <ListBox SelectionChanged="SettingsListBox_SelectionChanged" x:Name="SettingsListBox" Background="Transparent" BorderThickness="0" Margin="10,10,10,10" ItemContainerStyle="{StaticResource SettingsTreeView}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="8,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Foreground="#AAA" FontSize="12" FontWeight="Normal" FontFamily="{StaticResource Inter}" VerticalAlignment="Center" Text="{Binding Name}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ItemsControl.GroupStyle>
                                            <GroupStyle>
                                                <GroupStyle.ContainerStyle>
                                                    <Style TargetType="{x:Type GroupItem}">
                                                        <Setter Property="FrameworkElement.Margin" Value="0,12,0,0"/>
                                                    </Style>
                                                </GroupStyle.ContainerStyle>
                                                <GroupStyle.HeaderTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="8,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Foreground="#AAA" FontSize="12" FontWeight="Normal" FontFamily="{StaticResource Inter}" VerticalAlignment="Center" Text="{Binding Name}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </GroupStyle.HeaderTemplate>
                                            </GroupStyle>
                                        </ItemsControl.GroupStyle>
                                    </ListBox>
                                </Border>

                                <Border x:Name="PrimaryHostingElementSettings" Margin="280,30,0,0">
                                    <Grid>
                                        <Border x:Name="GeneralBorder" Visibility="Collapsed">
                                            <ScrollViewer VerticalScrollBarVisibility="Hidden">
                                                <StackPanel>
                                                    <StackPanel Height="Auto" VerticalAlignment="Top" Margin="10,10,10,0">
                                                        <StackPanel Margin="10,10,0,0">
                                                            <TextBlock Foreground="White" FontSize="19" Margin="0,0,0,10" Text="General" FontFamily="{StaticResource Inter}" Opacity="0.8"/>
                                                            <TextBlock Foreground="White" FontSize="15" Text="Customize general settings such as 'Save Scripts' and more." FontFamily="{StaticResource Inter}" Opacity="0.5"/>
                                                            <Border Height="5" Opacity="0.6" Margin="0,15,0,0" Background="#0d0d0d" CornerRadius="3"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    
<Border Background="Transparent" Margin="0,5,0,0" Height="80" CornerRadius="10">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Vertical" Margin="10,0">
            <TextBlock x:Name="AutoInjectTitle" Foreground="White" Opacity="0.8" FontSize="20" Text="Auto Inject"/>
            <TextBlock x:Name="AutoInjectDesc" Margin="0,5,0,0" Foreground="White" Opacity="0.5" FontSize="15" Text="Automatically Injects when instances are detected"/>
        </StackPanel>
        <ToggleButton x:Name="ToggleAutoInject" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,25,0"/>
    </Grid>
</Border>


                                                    <Border Background="Transparent" Margin="0,2,0,0" Height="80" CornerRadius="10">
                                                        <Grid Margin="10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Vertical" Margin="10,0">
                                                                <TextBlock x:Name="SaveSessionTitle" Foreground="White" Opacity="0.8" FontSize="20" Text="Save Scripts"/>
                                                                <TextBlock x:Name="SaveSessionDesc" Margin="0,5,0,0" Foreground="White" Opacity="0.5" FontSize="15" Text="Saves and re-loads your script tabs"/>
                                                            </StackPanel>
                                                            <ToggleButton x:Name="ToggleSaveScripts" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,25,0"/>
                                                        </Grid>
                                                    </Border>

                                                    <Border Visibility="Collapsed" Background="Transparent" Margin="0,2,0,0" Height="80" CornerRadius="10">
                                                        <Grid Margin="10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Vertical" Margin="10,0">
                                                                <TextBlock x:Name="UnlockFPSTitle" Foreground="White" Opacity="0.8" FontSize="20" Text="Unlock FPS"/>
                                                                <TextBlock x:Name="UnlockFPSDesc" Margin="0,5,0,0" Foreground="White" Opacity="0.5" FontSize="15" Text="Removes the FPS-Cap"/>
                                                            </StackPanel>
                                                            <ToggleButton x:Name="ToggleAutoReport" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,25,0"/>
                                                        </Grid>
                                                    </Border>

                                                    <!--
                                                    <Border Opacity="0.5" Background="Transparent" Margin="0,2,0,0" Height="80" CornerRadius="10">
                                                        <Grid Margin="10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Vertical" Margin="10,0">
                                                                <TextBlock x:Name="AutoExecuteTitle" Foreground="White" Opacity="0.8" FontSize="20" Text="Auto Execute"/>
                                                                <TextBlock x:Name="AutoExecuteDesc" Margin="0,5,0,0" Foreground="White" Opacity="0.5" FontSize="15" Text="This option is always on - drag .lua &amp; .txt files into 'autoexec'"/>
                                                            </StackPanel>
                                                            <ToggleButton x:Name="ToggleAutoExec" IsEnabled="False" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,25,0"/>
                                                        </Grid>
                                                    </Border>
                                                    -->
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Border>

                                        <Border x:Name="InterfaceBorder" Visibility="Collapsed">
                                            <ScrollViewer VerticalScrollBarVisibility="Hidden">
                                                <StackPanel>
                                                    <StackPanel Height="Auto" VerticalAlignment="Top" Margin="10,10,10,0">
                                                        <StackPanel Margin="10,10,0,0">
                                                            <TextBlock Foreground="White" FontSize="19" Margin="0,0,0,10" Text="Interface" FontFamily="{StaticResource Inter}" Opacity="0.8"/>
                                                            <TextBlock Foreground="White" FontSize="15" Text="Customize Interface settings." FontFamily="{StaticResource Inter}" Opacity="0.5"/>
                                                            <Border Height="5" Opacity="0.6" Margin="0,15,0,0" Background="#0d0d0d" CornerRadius="3"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <Border Background="Transparent" Margin="0,5,0,0" Height="80" CornerRadius="10">
                                                        <Grid Margin="10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Vertical" Margin="10,0">
                                                                <TextBlock x:Name="TopMostTitle" Foreground="White" Opacity="0.8" FontSize="20" Text="Top most"/>
                                                                <TextBlock x:Name="TopMostDesc" Margin="0,5,0,0" Foreground="White" Opacity="0.5" FontSize="15" Text="Makes Velocity sit on top of other windows"/>
                                                            </StackPanel>
                                                            <ToggleButton x:Name="ToggleTopMost" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,25,0"/>
                                                        </Grid>
                                                    </Border>

                                                    <Border Background="Transparent" Margin="0,5,0,0" Height="80" CornerRadius="10">
                                                        <Grid Margin="10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Vertical" Margin="10,0">
                                                                <TextBlock x:Name="HideVecTitle" Foreground="White" Opacity="0.8" FontSize="20" Text="Hide VelocityCosmic from capture"/>
                                                                <TextBlock x:Name="HideVelDesc" Margin="0,5,0,0" Foreground="White" Opacity="0.5" FontSize="15" Text="Hides this window from capturing software(s) such as OBS"/>
                                                            </StackPanel>
                                                            <ToggleButton x:Name="ToggleHideVel" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,25,0"/>
                                                        </Grid>
                                                    </Border>

                                                    <Border Background="Transparent" Margin="0,5,0,0" Height="Auto" CornerRadius="10">
                                                        <Grid Margin="10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Vertical" Margin="10,0">
                                                                <TextBlock x:Name="PreserveUiSizeTitle" Foreground="White" Opacity="0.8" FontSize="20" Text="Preserve Element Size"/>
                                                                <TextBlock x:Name="PreserveUiSizeDesc" Margin="0,5,0,0" Foreground="White" Opacity="0.5" FontSize="15" Text="Saves and restores the Width/Height of the Ui elements."/>
                                                            </StackPanel>
                                                            <ToggleButton x:Name="ToggleEnablePreserve" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,25,0"/>
                                                        </Grid>
                                                    </Border>

                                                    <Border Visibility="Collapsed" Background="Transparent" Margin="0,5,0,0" Height="80" CornerRadius="10">
                                                        <Grid Margin="10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Vertical" Margin="10,0">
                                                                <TextBlock x:Name="StartMinimizedTitle" Foreground="White" Opacity="0.8" FontSize="20" Text="Start Minimized"/>
                                                                <TextBlock x:Name="StartMinimizedDesc" Margin="0,5,0,0" Foreground="White" Opacity="0.5" FontSize="15" Text="Start the app minimized to system tray or taskbar"/>
                                                            </StackPanel>
                                                            <ToggleButton x:Name="ToggleStartMinimized" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,25,0"/>
                                                        </Grid>
                                                    </Border>

                                                    <Border Background="Transparent" Margin="0,5,0,0" Height="80" CornerRadius="10">
                                                        <Grid Margin="10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Vertical" Margin="10,0">
                                                                <TextBlock Foreground="White" Opacity="0.8" FontSize="20" Text="Save Window Size"/>
                                                                <TextBlock Margin="0,5,0,0" Foreground="White" Opacity="0.5" FontSize="15" Text="Save and restore window size on launch"/>
                                                            </StackPanel>
                                                            <ToggleButton x:Name="ToggleSaveWindowSize" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,25,0"/>
                                                        </Grid>
                                                    </Border>

                                                    <Border Background="Transparent" Margin="0,5,0,0" Height="Auto" CornerRadius="10">
                                                        <Grid Margin="10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Vertical" Margin="10,0">
                                                                <TextBlock x:Name="EnableBackgroundTitle" Foreground="White" Opacity="0.8" FontSize="20" Text="Enable Media-Background"/>
                                                                <TextBlock x:Name="EnableBackgroundDesc" Margin="0,5,0,0" Foreground="White" Opacity="0.5" FontSize="15" Text="Enable a custom background image for the interface"/>
                                                            </StackPanel>
                                                            <ToggleButton Checked="ToggleEnableBackground_Checked" Unchecked="ToggleEnableBackground_Unchecked" x:Name="ToggleEnableBackground" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,25,0"/>
                                                        </Grid>
                                                    </Border>

                                                    <Border x:Name="BackgroundUrlContainer" Background="Transparent" BorderBrush="#191919" BorderThickness="1.3" CornerRadius="10" Height="41" Margin="10,0,10,0" Opacity="1" Visibility="Visible">
                                                        <Grid>
                                                            <TextBox TextChanged="BackgroundUrlTextBox_TextChanged" x:Name="BackgroundUrlTextBox" Margin="10,5,10,5" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Foreground="White" Opacity="0.7" CaretBrush="White" FontSize="15" VerticalContentAlignment="Center">
                                                                <FrameworkElement.Style>
                                                                    <Style TargetType="{x:Type TextBox}">
                                                                        <Setter Property="Control.Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="{x:Type TextBox}">
                                                                                    <Grid>
                                                                                        <ScrollViewer x:Name="PART_ContentHost"/>
                                                                                        <TextBlock Text="https://MyCoolImageLink.png" FontStyle="Italic" Foreground="White" Opacity="0.3" IsHitTestVisible="False" Margin="2,0,0,0" VerticalAlignment="Center" Visibility="{Binding Text.IsEmpty, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                                    </Grid>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Style>
                                                                </FrameworkElement.Style>
                                                            </TextBox>
                                                        </Grid>
                                                    </Border>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Border>

                                        <Border x:Name="DebugBorderSettings" Visibility="Collapsed">
                                            <ScrollViewer VerticalScrollBarVisibility="Hidden">
                                                <StackPanel>
                                                    <StackPanel Height="Auto" VerticalAlignment="Top" Margin="10,10,10,0">
                                                        <StackPanel Margin="10,10,0,0">
                                                            <TextBlock Foreground="White" FontSize="19" Margin="0,0,0,10" Text="Debug Settings" FontFamily="{StaticResource Inter}" Opacity="0.8"/>
                                                            <TextBlock Foreground="White" FontSize="15" Text="Toggle certain Debugging features on or off." FontFamily="{StaticResource Inter}" Opacity="0.5"/>
                                                            <Border Height="5" Opacity="0.6" Margin="0,15,0,0" Background="#0d0d0d" CornerRadius="3"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <Border Background="Transparent" Margin="0,5,0,0" Height="80" CornerRadius="10">
                                                        <Grid Margin="10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Vertical" Margin="10,0">
                                                                <TextBlock x:Name="ToggleTerminalSaveTitle" Foreground="White" Opacity="0.8" FontSize="20" Text="Save output locally"/>
                                                                <TextBlock x:Name="ToggleTerminalSaveDesc" Margin="0,5,0,0" Foreground="White" Opacity="0.5" FontSize="15" Text="Saves the terminal output locally as a file."/>
                                                            </StackPanel>
                                                            <ToggleButton x:Name="DiscordRPCToggle" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,25,0"/>
                                                        </Grid>
                                                    </Border>

                                                    <Border Background="Transparent" Margin="0,5,0,0" Height="80" CornerRadius="10">
                                                        <Grid Margin="10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Vertical" Margin="10,0">
                                                                <TextBlock x:Name="ToggleExtLogTitle" Foreground="White" Opacity="0.8" FontSize="20" Text="Extended-Logging"/>
                                                                <TextBlock x:Name="ToggleExtLogDesc" Margin="0,5,0,0" Foreground="White" Opacity="0.5" FontSize="15" Text="Log more information and actions, useful for debugging"/>
                                                            </StackPanel>
                                                            <ToggleButton x:Name="TogleExtLog" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,25,0"/>
                                                        </Grid>
                                                    </Border>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="WelcomeMessage" Visibility="Collapsed" Grid.RowSpan="2">
            <Grid>
                <Border x:Name="WelcomeBackDrop" Background="Black" Opacity="0.6"/>
                <Border x:Name="WelcomeBorderMessageHost" Margin="60" Background="#080808" CornerRadius="10" BorderBrush="#191919" BorderThickness="2" Padding="20" HorizontalAlignment="Stretch" RenderTransformOrigin="0.5,0.5">
                    <UIElement.RenderTransform>
                        <ScaleTransform x:Name="WelcomeScale" ScaleX="0.94" ScaleY="0.94"/>
                    </UIElement.RenderTransform>
                    <Grid Margin="0,0,-12,-12">
                        <TextBlock FontFamily="{StaticResource Inter}" FontSize="20" FontWeight="SemiBold" Foreground="White" Opacity="1" Margin="10,10,0,0" VerticalAlignment="Top" HorizontalAlignment="Left">
                            <Run Text="Hey "/>
                            <Run Text="{x:Static sys:Environment.UserName}"/>
                            <Run Text=", welcome to Velocity!"/>
                        </TextBlock>
                        <TextBlock Text="Velocity now features a better and more lightweight user interface with improved performance and stability" FontFamily="{StaticResource Inter}" FontSize="16" FontWeight="Normal" Foreground="White" Opacity="0.6" TextWrapping="Wrap" Height="45" Width="577" Margin="10,65,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                        <TextBlock Text="Ui updates and fixes:" FontFamily="{StaticResource Inter}" FontSize="18" FontWeight="Medium" Foreground="White" Opacity="0.9" TextWrapping="Wrap" Height="25" Width="460" Margin="10,137,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                        <TextBlock Text="[+] Complete new layout and feel of the Ui" FontFamily="{StaticResource Inter}" FontSize="16" FontWeight="Normal" Foreground="White" Opacity="0.5" TextWrapping="Wrap" Height="20" Width="460" Margin="10,174,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                        <TextBlock Text="[+] Switched to WebView for better performance" FontFamily="{StaticResource Inter}" FontSize="16" FontWeight="Normal" Foreground="White" Opacity="0.5" TextWrapping="Wrap" Height="20" Width="460" Margin="10,204,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                        <TextBlock Text="[+] Removed client manager in favour of automatic client detection and injection" FontFamily="{StaticResource Inter}" FontSize="16" FontWeight="Normal" Foreground="White" Opacity="0.5" TextWrapping="Wrap" Height="20" Margin="10,234,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                        <TextBlock Text="[+] Added Auto-Inject and other cool Ui-related settings" FontFamily="{StaticResource Inter}" FontSize="16" FontWeight="Normal" Foreground="White" Opacity="0.5" TextWrapping="Wrap" Height="20" Margin="10,264,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                        <Image Source="/Resource/tabs/vel/vel_meteor-hq.png" Height="80" Width="80" RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,10,10,0"/>
                        <TextBlock Text="Simply Press 'Continue' to close this pop-up and enter Velocity!" FontFamily="{StaticResource Inter}" FontSize="16" FontWeight="Medium" Foreground="White" Opacity="0.8" TextWrapping="Wrap" Height="20" Margin="10,309,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                        <Button Click="ContinueButton_Click" Style="{DynamicResource HoverOpacityButton}" FontFamily="{StaticResource Inter}" FontSize="15" FontWeight="Medium" ToolTip="Enter Velocity" Content="Continue" Foreground="White" Height="40" Width="90" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="RenamePopup" Panel.ZIndex="2" Visibility="Collapsed" Grid.RowSpan="2">
            <Grid>
                <Border x:Name="ShadowBlockRenameTab" Opacity="0.5" Background="Black"/>
                <Border x:Name="CoreBorderRename" Visibility="Collapsed" ClipToBounds="True" Height="215" Width="460" Background="#080808" BorderBrush="#191919" BorderThickness="2" CornerRadius="10">
                    <Grid>
                        <StackPanel Height="58" VerticalAlignment="Top" Margin="10,10,10,0">
                            <Grid>
                                <Image Opacity="0.8" Source="/Resource/Tabs/Menu/Tab_Rename.png" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Left" Margin="7,8,0,9" Width="55"/>
                                <TextBlock VerticalAlignment="Top" Margin="70,15,0,0" FontFamily="Inter" FontSize="18" Foreground="White" Opacity="0.8" Text="Rename Tab"/>
                                <TextBlock VerticalAlignment="Top" Margin="70,40,0,0" FontFamily="Inter" FontSize="14" Foreground="White" Opacity="0.5" Text="Enter the new name below into the box and press 'Ok'."/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Height="50" VerticalAlignment="Top" Margin="10,85,10,0">
                            <Grid>
                                <Border Background="#080808" BorderBrush="#191919" BorderThickness="2" Height="45" CornerRadius="8">
                                    <TextBox x:Name="RenameTabTextBox" CaretBrush="White" Margin="8,12,8,12" Background="Transparent" Foreground="White" FontFamily="Inter" FontSize="16" Opacity="0.8" BorderThickness="0"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                        <Border x:Name="BottomBorderTabRename" Height="50" VerticalAlignment="Bottom" Margin="5,0,0,5" Background="Transparent">
                            <Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Height="40" VerticalAlignment="Bottom" Margin="0,0,20,10">
                                    <Button Click="CancelButton_Click" Width="65" Height="36" Cursor="Hand" Content="Cancel" FontFamily="{DynamicResource Inter}" FontSize="15" FontWeight="Medium" Margin="0,0,10,0" Style="{DynamicResource HoverOpacityButton}" Foreground="White"/>
                                    <Button Click="OkButton_Click" Width="65" Height="36" Cursor="Hand" Content="Ok" FontFamily="{DynamicResource Inter}" FontSize="15" FontWeight="Medium" Margin="0,0,7,0" Style="{DynamicResource HoverOpacityButton}" Foreground="White"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
